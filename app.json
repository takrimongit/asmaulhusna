{
  "expo": {
    "name": "Asma Ul Husna",
    "slug": "asmaul-husna",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2818"
    },
    "scheme": "asmaulhusna",
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Amiri-Regular.ttf",
            "./assets/fonts/Amiri-Bold.ttf"
          ]
        }
      ],
      "expo-audio"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.helpables.asmaulhusna",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0D2818"
      },
      "package": "com.helpables.asmaulhusna"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2fbc51fc-28b7-4e82-a34c-0c9713da18d5"
      }
    },
    "owner": "takrimk",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2fbc51fc-28b7-4e82-a34c-0c9713da18d5"
    },
    "platforms": [
      "ios",
      "android"
    ]
  }
}
